# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force LF for YAML and Helm templates
*.yaml text eol=lf
*.yml  text eol=lf
*.txt  text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.sh   text eol=lf

# Windows scripts keep CRLF
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Binaries
*.png  binary
*.jpg  binary
*.gz   binary
*.tgz  binary
